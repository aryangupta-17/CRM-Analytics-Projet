      <aliases enabled='yes' />
      <column caption='Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_1678456792825856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(IF [Status] = &quot;Converted&quot; THEN [Lead ID] END)&#13;&#10;/ COUNT([Lead ID]) * 100' />
      </column>
      <column caption='Conversion Leads1' datatype='real' name='[Calculation_1678456796684290]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Status] = &quot;Customer&quot; THEN [Lead ID] END&#13;&#10;)&#13;&#10;/ COUNT([Lead ID])' />
      </column>
      <column caption='Conversion Category' datatype='string' name='[Calculation_1678456800833539]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Status] = &quot;Converted&quot; THEN &quot;Converted&quot;&#13;&#10;ELSE &quot;Not Converted&quot;&#13;&#10;END' />
      </column>
      <column datatype='string' name='[Country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
      <column datatype='string' name='[Status]' role='dimension' type='nominal' />
