      <column-instance column='[Calculation_1678456800833539]' derivation='None' name='[none:Calculation_1678456800833539:nk]' pivot='key' type='nominal' />
      <column-instance column='[Status]' derivation='None' name='[none:Status:nk]' pivot='key' type='nominal' />
      <layout dim-ordering='alphabetic' measure-ordering='alphabetic' show-structure='true' />
      <style>
        <style-rule element='mark'>
          <encoding attr='color' field='[none:Status:nk]' palette='red_10_0' type='palette'>
            <map to='#ae123a'>
              <bucket>&quot;Untouched&quot;</bucket>
            </map>
            <map to='#c8203b'>
              <bucket>&quot;SQL&quot;</bucket>
            </map>
            <map to='#de3540'>
              <bucket>&quot;Qualified&quot;</bucket>
            </map>
            <map to='#ed524a'>
              <bucket>&quot;Prospect&quot;</bucket>
            </map>
            <map to='#f46f5c'>
              <bucket>&quot;Nurturing&quot;</bucket>
            </map>
            <map to='#fa8b74'>
              <bucket>&quot;MQL&quot;</bucket>
            </map>
            <map to='#fda493'>
              <bucket>&quot;Disqualified&quot;</bucket>
            </map>
            <map to='#ffbeb2'>
              <bucket>&quot;Converted&quot;</bucket>
            </map>
          </encoding>
          <encoding attr='color' field='[none:Calculation_1678456800833539:nk]' type='palette'>
            <map to='#d3d3d3'>
              <bucket>&quot;Converted&quot;</bucket>
            </map>
            <map to='#d62728'>
              <bucket>&quot;Not Converted&quot;</bucket>
            </map>
          </encoding>
        </style-rule>
