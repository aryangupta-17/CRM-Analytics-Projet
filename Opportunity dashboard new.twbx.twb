          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Conversion Rate' datatype='real' default-format='p0.00%' name='[Calculation_0210334256181249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0210334257156101] / [Calculation_0846401910960128] * 100' />
      </column>
      <column caption='Loss  Opportunities' datatype='integer' name='[Calculation_0210334256308226]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Status] = &quot;Closed Lost&quot; THEN [Opportunity ID] END&#13;&#10;)' />
      </column>
      <column caption='Loss Rate' datatype='real' name='[Calculation_0210334256926723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([Won] = FALSE,1,0))&#13;&#10;/&#13;&#10;COUNT([Opportunity ID])' />
      </column>
      <column caption='Win Rate' datatype='real' name='[Calculation_0210334257057796]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([Won] = TRUE,1,0))&#13;&#10;/&#13;&#10;COUNT([Opportunity ID])' />
      </column>
      <column caption='Won Opportunities' datatype='integer' name='[Calculation_0210334257156101]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Status] = &quot;Closed Won&quot; THEN [Opportunity ID] END&#13;&#10;)' />
      </column>
      <column caption='Active opportunities' datatype='string' name='[Calculation_0210334270144524]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Status] = &quot;Open&quot; THEN [Opportunity ID] END' />
      </column>
      <column caption='Total Opportunities' datatype='integer' name='[Calculation_0846401910960128]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([Opportunity ID])' />
      </column>
      <column caption='close won deals' datatype='integer' name='[Calculation_0846401911095297]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [Won] = TRUE THEN [Opportunity ID] END)' />
      </column>
      <column caption='Close won %' datatype='real' name='[Calculation_0846401916145666]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Stage] = &quot;Closed Won&quot; THEN [Opportunity ID] END&#13;&#10;)&#13;&#10;/&#13;&#10;COUNT([Opportunity ID])' />
      </column>
      <column caption='Oppo status group' datatype='string' name='[Calculation_0846401916686339]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Stage] = &quot;Closed Won&quot; THEN &quot;Closed Won&quot;&#13;&#10;ELSE &quot;Others&quot;&#13;&#10;END' />
      </column>
      <column caption='close won opportunities' datatype='integer' name='[Calculation_0846401953890308]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT(&#13;&#10;IF [Stage] = &quot;Closed Won&quot; THEN [Opportunity ID] END&#13;&#10;)' />
      </column>
      <column caption='won deals' datatype='integer' name='[Calculation_1430792392962048]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Won] = TRUE THEN 1 ELSE 0 END' />
      </column>
      <column caption='win rate percentage' datatype='real' name='[Calculation_1430792393179137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_1430792392962048]) / COUNT([Opportunity ID])' />
      </column>
      <column caption='zero' datatype='integer' name='[Calculation_1430792394280962]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='Acive opportunities count' datatype='string' name='[Calculation_1430792400171012]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Stage] != &quot;Closed Won&quot; AND [Stage] != &quot;Closed Lost&quot; &#13;&#10;THEN [Opportunity ID] &#13;&#10;END' />
      </column>
      <column caption='won count' datatype='integer' name='[Calculation_1430792404471813]' role='measure' type='quantitative'>
