      </column>
      <column caption='Conversion rate percentage' datatype='real' default-format='p0.00%' name='[Calculation_1430792430592007]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0210334257156101] / [Calculation_0846401910960128] * 100' />
      </column>
      <column caption='ACTIVE STATUS' datatype='string' name='[Calculation_1430792434835465]' role='dimension' type='nominal'>
